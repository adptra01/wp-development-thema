{
    "version": 3,
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "settings": {
        "appearanceTools": true,
        "background": {
            "backgroundImage": true
        },
        "color": {
            "palette": [
                {
                    "slug": "surface",
                    "color": "#09090b",
                    "name": "Surface"
                },
                {
                    "slug": "surface-raised",
                    "color": "#0e0e11",
                    "name": "Surface Raised"
                },
                {
                    "slug": "neutral",
                    "color": "#18181b",
                    "name": "Neutral"
                },
                {
                    "slug": "border",
                    "color": "#27272a",
                    "name": "Border"
                },
                {
                    "slug": "text-primary",
                    "color": "#f4f4f5",
                    "name": "Text Primary"
                },
                {
                    "slug": "text-secondary",
                    "color": "#a1a1aa",
                    "name": "Text Secondary"
                },
                {
                    "slug": "text-tertiary",
                    "color": "#71717a",
                    "name": "Text Tertiary"
                },
                {
                    "slug": "accent",
                    "color": "#22c55e",
                    "name": "Accent Green"
                },
                {
                    "slug": "accent-dim",
                    "color": "#166534",
                    "name": "Accent Dim"
                }
            ],
            "duotone": [],
            "gradients": [],
            "link": false,
            "text": true,
            "background": true,
            "button": false,
            "heading": true,
            "caption": true
        },
        "typography": {
            "fontFamilies": [
                {
                    "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif",
                    "slug": "system",
                    "name": "System"
                },
                {
                    "fontFamily": "'Geist', sans-serif",
                    "slug": "geist",
                    "name": "Geist"
                },
                {
                    "fontFamily": "'Inter', sans-serif",
                    "slug": "inter",
                    "name": "Inter"
                },
                {
                    "fontFamily": "'JetBrains Mono', monospace",
                    "slug": "mono",
                    "name": "JetBrains Mono"
                }
            ],
            "fontSizes": [
                { "slug": "xs", "size": "0.75rem", "name": "XS" },
                { "slug": "sm", "size": "0.875rem", "name": "SM" },
                { "slug": "base", "size": "1rem", "name": "Base" },
                { "slug": "lg", "size": "1.125rem", "name": "LG" },
                { "slug": "xl", "size": "1.25rem", "name": "XL" },
                { "slug": "2xl", "size": "1.5rem", "name": "2XL" },
                { "slug": "3xl", "size": "1.875rem", "name": "3XL" },
                { "slug": "4xl", "size": "2.25rem", "name": "4XL" },
                { "slug": "5xl", "size": "3rem", "name": "5XL" },
                { "slug": "6xl", "size": "3.75rem", "name": "6XL" },
                { "slug": "7xl", "size": "4.5rem", "name": "7XL" }
            ],
            "dropCap": false,
            "fluid": true,
            "letterSpacing": true,
            "lineHeight": true,
            "textAlign": true,
            "textDecoration": true,
            "textTransform": true,
            "writingMode": false
        },
        "spacing": {
            "blockGap": true,
            "margin": true,
            "padding": true,
            "units": ["px", "em", "rem", "vh", "vw", "%"],
            "customSpacingSize": true,
            "defaultSpacingSizes": true
        },
        "border": {
            "color": true,
            "radius": true,
            "style": true,
            "width": true
        },
        "blocks": {
            "core/paragraph": {
                "typography": {
                    "fontFamilies": [
                        { "fontFamily": "'Inter', sans-serif", "slug": "inter", "name": "Inter" }
                    ]
                }
            },
            "core/heading": {
                "typography": {
                    "fontFamilies": [
                        { "fontFamily": "'Geist', sans-serif", "slug": "geist", "name": "Geist" }
                    ]
                }
            },
            "core/button": {
                "border": { "radius": true }
            }
        }
    },
    "styles": {
        "color": {
            "background": "#09090b",
            "text": "#f4f4f5"
        },
        "typography": {
            "fontFamily": "var(--wp--preset--font-family--inter)",
            "fontSize": "1rem"
        },
        "blocks": {
            "core/heading": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--geist)",
                    "fontWeight": "500",
                    "letterSpacing": "-0.02em"
                }
            },
            "core/paragraph": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--inter)",
                    "lineHeight": "1.75"
                }
            }
        }
    },
    "customTemplates": [
        {
            "name": "page-home",
            "title": "Homepage (Lumina)",
            "postTypes": [ "page" ]
        }
    ]
}
